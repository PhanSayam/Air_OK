@startuml air_hockey

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam linetype ortho

' ===== MODEL =====
package "model" #E1F5EE {

  class Player {
    - name: String
    - score: int
    + getScore(): int
    + addPoint(): void
    + applyOwnGoal(): void
  }

  class Paddle {
    - position: Vector3f
    - radius: float
    - sizeMultiplier: float
    + move(target: Vector3f): void
    + getRadius(): float
    + resize(factor: float): void
  }

  class Puck {
    - position: Vector3f
    - velocity: Vector3f
    - radius: float
    - speedMultiplier: float
    - sizeMultiplier: float
    + applySmash(factor: float): void
    + applyLift(spinAxis: Vector3f): void
    + applyFlip(): void
    + reset(position: Vector3f): void
  }

  class Table {
    - width: float
    - length: float
    - neutralZoneRatio: float
    + isInGoal(pos: Vector3f): int
    + isInPaddleZone(pos: Vector3f, side: int): boolean
    + isInNeutralZone(pos: Vector3f): boolean
    + getBounds(): BoundingBox
  }

  class PowerUp {
    - type: PowerUpType
    - position: Vector3f
    - duration: float
    - active: boolean
    + apply(p: Player, puck: Puck): void
    + expire(): void
    + isExpired(): boolean
  }

  enum PowerUpType {
    SPEED_PLUS
    SIZE_PLUS
    SIZE_MINUS
    SHOT_ON_GOAL
    PADDLE_PLUS
    PADDLE_MINUS
  }

  class ScoreRules {
    + {static} WIN_SCORE: int = 12
    + {static} applyOwnGoal(score: int): int
    + {static} hasWon(score: int): boolean
    + {static} clamp(score: int): int
  }

  Player "1" o-- "1" Paddle
  PowerUp --> PowerUpType
  PowerUp "0..*" --o "1" Table
}

' ===== CONTROLLER =====
package "controller" #EEEDFE {

  class GameState {
    - puck: Puck
    - players: Player[2]
    - paddles: Paddle[2]
    - powerUps: List<PowerUp>
    - physicsEngine: PhysicsEngine
    - sceneBuilder: SceneBuilder
    - hud: HUD
    - aiController: AIController
    + initialize(app: Application): void
    + update(tpf: float): void
    + cleanup(app: Application): void
    - handleGoal(side: int): void
    - checkWin(): void
    - spawnPowerUp(): void
  }

  class MenuState {
    - selectedMode: GameMode
    + initialize(app: Application): void
    + onSinglePlayer(): void
    + onVersus(): void
    + onTournament(): void
  }

  class EndGameState {
    - winner: Player
    + initialize(app: Application): void
    + onRestart(): void
    + onMenu(): void
  }

  class PlayerInputHandler {
    - paddle: Paddle
    - zone: BoundingBox
    - playerId: int
    + registerInputs(im: InputManager): void
    + onAnalog(name: String, value: float, tpf: float): void
    + onAction(name: String, pressed: boolean, tpf: float): void
  }

  enum GameMode {
    SINGLE_PLAYER
    VERSUS
    TOURNAMENT
  }

  GameState --> Puck
  GameState --> Player
  GameState --> Paddle
  GameState --> PowerUp
  GameState --> ScoreRules
  GameState --> GameMode
  MenuState --> GameMode
}

' ===== AI =====
package "controller.ai" #FAECE7 {

  abstract class AIController {
    # paddle: Paddle
    # puck: Puck
    # difficulty: float
    + update(tpf: float): void
    + {abstract} computeMove(): Vector3f
    # predictPuckPosition(tpf: float): Vector3f
  }

  class AggressiveOpponent {
    - attackSpeed: float
    + computeMove(): Vector3f
    + intercept(puck: Puck): void
  }

  class WeakeningOpponent {
    - weakenRate: float
    - currentStrength: float
    + computeMove(): Vector3f
    + onPointScored(): void
  }

  class DefensiveOpponent {
    - defendZone: float
    + computeMove(): Vector3f
    + guardGoal(): void
  }

  AIController <|-- AggressiveOpponent
  AIController <|-- WeakeningOpponent
  AIController <|-- DefensiveOpponent

  GameState --> AIController
}

' ===== INFRASTRUCTURE =====
package "infrastructure" #F1EFE8 {

  class PhysicsEngine {
    - bulletAppState: BulletAppState
    + register(puck: Puck, paddles: Paddle[], table: Table): void
    + update(tpf: float): void
    + onCollision(event: PhysicsCollisionEvent): void
    + applyImpulse(body: PhysicsRigidBody, force: Vector3f): void
  }

  class SceneBuilder {
    - assetManager: AssetManager
    - rootNode: Node
    + buildScene(table: Table, puck: Puck, paddles: Paddle[]): void
    + attachPowerUp(pu: PowerUp): void
    + detachPowerUp(pu: PowerUp): void
    + updatePuckSpatial(puck: Puck): void
  }

  class HUD {
    - scoreText: BitmapText
    - timerText: BitmapText
    - messageText: BitmapText
    + updateScore(p1: int, p2: int): void
    + showMessage(msg: String): void
    + showEndScreen(winner: Player): void
    + hide(): void
  }

  GameState --> PhysicsEngine
  GameState --> SceneBuilder
  GameState --> HUD
  PlayerInputHandler --> Paddle
}

@enduml
